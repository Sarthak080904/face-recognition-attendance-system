DB_HOST=localhost
DB_PORT=5432
DB_NAME=attendance_system
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# Online hosting providers like Neon/Supabase usually give one PostgreSQL URL.
# Keep this blank for local development. Use it on Render when hosted.
DATABASE_URL=

# LBPH confidence: lower is stricter, higher is easier to match.
# Start with 80. If recognition fails often, try 90. If wrong people match, try 65.
FACE_CONFIDENCE_THRESHOLD=80

# Used by Flask login sessions. Change this to any long random text.
SECRET_KEY=change-this-secret-key
